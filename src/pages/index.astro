---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Hero from '../sections/Hero';
import ProblemAndVideo from '../sections/ProblemAndVideo';
import Solutions from '../sections/Solutions';
import TrustStrip from '../sections/TrustStrip';
import Team from '../sections/Team';
import Contact from '../sections/Contact';
import Footer from '../sections/Footer';
---

<Layout title="Aiscend" description="Transform your business with AI & automation solutions.">
  <button onclick="document.getElementById('hero')?.scrollIntoView({behavior:'smooth',block:'start'})" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-background focus:text-foreground focus:px-3 focus:py-2 focus:rounded-md">
    Skip to content
  </button>
  <Header client:load />
  <main id="page" class="min-h-screen">
    <Hero client:load />
    <ProblemAndVideo client:visible />
    <Solutions client:load />
    <TrustStrip client:visible />
    <Team client:visible />
    <Contact client:visible />
    <Footer client:visible />
  </main>
</Layout>
